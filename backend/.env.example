# ============================================
# AI Platform 后端配置
# 把这个文件复制为 .env，然后填入真实值
# !!! .env 文件绝对不要提交到 git !!!
# ============================================

# --- 应用基础 ---
APP_NAME="AI Platform"
DEBUG=true
SECRET_KEY="CHANGE-ME-TO-A-RANDOM-LONG-STRING"  # 用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成

# --- 数据库 ---
# SQLite（默认，适合本地单机）
DATABASE_URL="sqlite+aiosqlite:///./ai_platform.db"
# PostgreSQL（生产环境推荐）
# DATABASE_URL="postgresql+asyncpg://user:pass@localhost/ai_platform"

# --- 管理员账号（仅此账号能使用功能4/5）---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE-ME-BEFORE-FIRST-RUN"   # 第一次启动前必改！

# --- AI 服务（至少配置一个）---
# Anthropic Claude
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"

# OpenAI / DeepSeek（DeepSeek 完全兼容 OpenAI SDK）
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.deepseek.com"   # 用 DeepSeek 省钱；用官方 OpenAI 就填 https://api.openai.com/v1
OPENAI_MODEL="deepseek-chat"

# 默认使用哪个 AI (anthropic / openai)
DEFAULT_AI_PROVIDER="openai"

# --- ComfyUI（图片生成，功能3需要）---
COMFYUI_BASE_URL="http://127.0.0.1:8188"
COMFYUI_ENABLED=false

# --- CORS ---
CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# --- 抓取限速（保护账号）---
CRAWL_MIN_DELAY_SEC=2
CRAWL_MAX_DELAY_SEC=5
CRAWL_MAX_CONCURRENT=1

# --- 发布限速（保护账号）---
PUBLISH_MIN_DELAY_SEC=30
PUBLISH_MAX_DELAY_SEC=120
PUBLISH_DEFAULT_TO_DRAFT=true   # 永远为 true，不要改！
